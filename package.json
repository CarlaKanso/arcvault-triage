{
  "name": "arcvault-triage",
  "version": "1.0.0",
  "description": "AI-powered intake & triage pipeline for inbound customer requests (Valsoft AI Engineer assessment)",
  "type": "module",
  "scripts": {
    "serve": "tsx src/server.ts",
    "serve:watch": "tsx watch src/server.ts",
    "triage": "tsx src/run.ts",
    "compare": "tsx src/compare.ts",
    "n8n:build": "tsx scripts/build-n8n.ts",
    "n8n:post": "tsx scripts/post-samples.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
