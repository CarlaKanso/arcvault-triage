# ---- LLM providers (you only need the one you run with; more = the compare demo) ----
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...

# Default provider + model when you don't pass --provider / --model on the CLI.
# Also used by the webhook server (`npm run serve`). provider: openai | groq | gemini
TRIAGE_PROVIDER=openai
TRIAGE_MODEL=gpt-4o-mini

# ---- Webhook server (`npm run serve`); both optional ----
# Port for the pure-code HTTP server (default 3000).
PORT=3000
# Set to require an `x-api-key: <value>` header on every request. Leave unset to disable auth.
API_KEY=

# ---- Google Sheets sink (optional; only needed for `--sheets`) ----
# Path to a Google service-account JSON key file. Share your Sheet with the
# service account's client_email (Editor) so it can append rows.
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
# The spreadsheet ID from the Sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEET_ID=
